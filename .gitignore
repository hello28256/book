.vitepress/dist/
# docs:gen-commits 生成的提交记录（每次 build 重新生成，不入仓）
docs/.vitepress/data/

# Python（保留 .env 警告）
__pycache__/
*.py[cod]
.venv/
venv/

# Node
node_modules/
*.log

# 环境变量
.env
.env.*

# macOS
.DS_Store

# IDE
.vscode/
.idea/
*.swp
